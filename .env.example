COMPOSE_PROJECT_NAME=ibkr_show

FRONTEND_PORT=8080
BACKEND_PORT=8000
ES_PORT=9200
REDIS_PORT=6379
ES_JAVA_OPTS=-Xms512m -Xmx512m
APP_ENV=docker

# 以下为 fallback 默认值。Docker 首次启动后推荐通过页面初始化管理员账号，
# 初始化后这些字段仅作为应急 fallback，正常情况下不会被使用。
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
AUTH_SESSION_SECRET=change-me-to-a-random-string
CONFIG_ENCRYPTION_KEY=change-me-to-a-random-config-encryption-key
DAILY_REVIEW_INTERNAL_TOKEN=change-me-to-a-random-token

# Longbridge market-event sync uses existing OpenAPI / SDK OAuth config only.
# Backend market event synchronization does not use MCP.
LONGBRIDGE_ENABLE=true
LONGBRIDGE_OPENAPI_OAUTH_CLIENT_ID=
LONGBRIDGE_OPENAPI_OAUTH_FILE=./data/config/longbridge_openapi_oauth.json
LONGBRIDGE_OPENAPI_OAUTH_SCOPE=

# true: worker-init 自动导入脱敏样例数据，适合首次体验；
# false: 不导入样例数据，适合接入真实 IBKR 数据。
DEMO_MODE=true

# 业务配置请启动后在后台管理页面填写：
# - IBKR Flex Token / Query ID: /admin/ibkr
# - LLM Provider / API Key / Model: /admin/llm
# - LongBridge OAuth: /admin/longbridge-mcp
# - Email SMTP: /admin/email
